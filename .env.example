# Exemple de plantilla .env per Rebuscada
# Ruta al fitxer de diccionari (JSON)
DICCIONARI_PATH=data/diccionari.json

# Paraula per defecte del dia (sense extensió .json)
DEFAULT_REBUSCADA=compliment

# Port del servidor d'administració (opcional)
ADMIN_PORT=3000

# Port del servidor (opcional)
PORT=8000

# Origins permesos per CORS (separats per comes)
# En desenvolupament: http://localhost:3000,https://rebuscada.cat
# En producció: https://rebuscada.cat
ALLOWED_ORIGINS=https://rebuscada.cat,https://www.rebuscada.cat,http://localhost:3000

# Mida del cache de rankings
RANKING_CACHE_SIZE=10

# Dies després dels quals s'esborren les competicions inactives
COMPETITION_EXPIRY_DAYS=2

# Contrasenya d'administració
ADMIN_PASSWORD=???

# CLAU ADMIN <-> SERVER
ADMIN_SHARED_SECRET=???

# Ruta de la base de dades d'estadístiques (per defecte: data/stats.db)
STATS_DB_PATH=data/stats.db

# API Gemini
GEMINI_API=???
# Clau API d'OpenAI (per a l'algorisme de proximitat openai)
# Obt�n-la a: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-api-key-here
